# OpenRouter / LLM
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM call retries (transport-level, exponential backoff)
LLM_RETRIES=3

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Manim execution
MAX_RETRIES=3
RENDER_TIMEOUT=120
# Render quality: low (480p), medium (720p), high (1080p), p (1440p), k (4k)
RENDER_QUALITY=medium
# Frame rate override; leave unset for manim's default per quality
#RENDER_FPS=30

# Video generation defaults
VIDEO_LENGTH=1.0
EXPLANATION_DEPTH=detailed
VIDEO_ORIENTATION=landscape
DURATION_MODE=guide

# Storyboard planning stage (plan timed sections before writing code)
STORYBOARD_ENABLED=true

# Visual QA: multimodal review of rendered frames with layout auto-fix.
# Off by default — each attempt adds a vision LLM call and a re-render.
VISUAL_QA_ENABLED=false
VISUAL_QA_MAX_ATTEMPTS=1
VISUAL_QA_FRAMES=6

# API server
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000
